        {
          "_type": "UMLPackage",
          "_id": "pkg-seq",
          "_parent": {"$ref": "model-001"},
          "name": "3. Diagrama de Secuencia",
          "ownedElements": [
            {
              "_type": "UMLCollaboration",
              "_id": "collab-seq",
              "_parent": {"$ref": "pkg-seq"},
              "name": "Registrar Gasto",
              "ownedElements": [
                {"_type": "UMLLifeline", "_id": "ll-u",  "_parent": {"$ref": "collab-seq"}, "name": "usuario : Usuario"},
                {"_type": "UMLLifeline", "_id": "ll-s",  "_parent": {"$ref": "collab-seq"}, "name": "sistema : Flask"},
                {"_type": "UMLLifeline", "_id": "ll-bd", "_parent": {"$ref": "collab-seq"}, "name": "bd : BaseDatos"},
                {
                  "_type": "UMLMessage", "_id": "msg-1", "_parent": {"$ref": "collab-seq"},
                  "name": "1. Abre formulario de gasto",
                  "source": {"$ref": "ll-u"}, "target": {"$ref": "ll-s"},
                  "messageSort": "synchCall"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-2", "_parent": {"$ref": "collab-seq"},
                  "name": "2. Muestra formulario",
                  "source": {"$ref": "ll-s"}, "target": {"$ref": "ll-u"},
                  "messageSort": "reply"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-3", "_parent": {"$ref": "collab-seq"},
                  "name": "3. Ingresa datos del gasto",
                  "source": {"$ref": "ll-u"}, "target": {"$ref": "ll-s"},
                  "messageSort": "synchCall"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-4", "_parent": {"$ref": "collab-seq"},
                  "name": "4. Validar y guardar gasto",
                  "source": {"$ref": "ll-s"}, "target": {"$ref": "ll-bd"},
                  "messageSort": "synchCall"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-5", "_parent": {"$ref": "collab-seq"},
                  "name": "5. Confirmacion OK",
                  "source": {"$ref": "ll-bd"}, "target": {"$ref": "ll-s"},
                  "messageSort": "reply"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-6", "_parent": {"$ref": "collab-seq"},
                  "name": "6. Gasto registrado correctamente",
                  "source": {"$ref": "ll-s"}, "target": {"$ref": "ll-u"},
                  "messageSort": "reply"
                },
                {
                  "_type": "UMLMessage", "_id": "msg-7", "_parent": {"$ref": "collab-seq"},
                  "name": "[si excede] Alerta de presupuesto",
                  "source": {"$ref": "ll-s"}, "target": {"$ref": "ll-u"},
                  "messageSort": "reply"
                }
              ]
            },
            {
              "_type": "UMLSequenceDiagram",
              "_id": "diag-seq",
              "_parent": {"$ref": "pkg-seq"},
              "name": "Secuencia - Registrar Gasto",
              "ownedViews": [
