                {"_type": "UMLLifelineView", "_id": "vll-bd", "_parent": {"$ref": "diag-seq"}, "model": {"$ref": "ll-bd"}, "left": 500, "top": 40, "width": 140, "height": 380}
              ]
            }
          ]
        },

